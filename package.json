{
  "name": "easy-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10.33.2 <11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "harness:check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "handoff:check": "node scripts/verify-handoff.mjs && pnpm harness:check"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@tailwindcss/postcss": "4.2.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "prettier": "^3.7.4",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
